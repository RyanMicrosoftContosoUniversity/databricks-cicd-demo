      "link": null,
      "locked": false,
      "text": "This Topology can also be simplified to run on the same Agent Pool, whereby there aren't restrictions on what the VM Pool \ncan deploy to (as was in the design above where each VM had a dedicated environment)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This Topology can also be simplified to run on the same Agent Pool, whereby there aren't restrictions on what the VM Pool \ncan deploy to (as was in the design above where each VM had a dedicated environment)",
